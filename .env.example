# ===========================================
# ARCHIVO DE EJEMPLO - VARIABLES DE ENTORNO
# ===========================================
# 
# Este es un archivo de ejemplo. Copia este archivo como .env
# y configura los valores según tu entorno específico.
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio
# ya que contiene información sensible.
# ===========================================

# Configuración de la aplicación
SPRING_APPLICATION_NAME=edu_virtual_ufps
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Configuración de base de datos MySQL (Principal)
SPRING_DATASOURCE_URL=jdbc:mysql://mysql-db:3306/edu_virtual_ufps?useUnicode=true&characterEncoding=UTF-8&useJDBCCompliantTimezoneShift=true&useLegacyDatetimeCode=false&serverTimezone=America/Bogota
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=TU_PASSWORD_MYSQL
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Configuración de MySQL para Docker Compose
MYSQL_ROOT_PASSWORD=TU_PASSWORD_MYSQL
MYSQL_DATABASE=edu_virtual_ufps
MYSQL_USER=app_user
MYSQL_PASSWORD=TU_PASSWORD_MYSQL

# Configuración de Oracle (Base de datos externa)
ORACLE_DATASOURCE_URL=jdbc:oracle:thin:@TU_HOST_ORACLE:1522:UFPS
ORACLE_DATASOURCE_USERNAME=TU_USUARIO_ORACLE
ORACLE_DATASOURCE_PASSWORD=TU_PASSWORD_ORACLE
ORACLE_DATASOURCE_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
ORACLE_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=60000
ORACLE_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
ORACLE_DATASOURCE_HIKARI_READ_ONLY=true

# Configuración de Google OAuth2
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=email,profile
APP_FRONTEND_SUCCESS_URL=http://localhost:5173/login/success
APP_FRONTEND_MAIL_URL=https://gitlab.applab.ufps.edu.co/cambiar-contrasena?token=

# Configuración de AWS S3
CLOUD_AWS_CREDENTIALS_ACCESS_KEY=TU_AWS_ACCESS_KEY
CLOUD_AWS_CREDENTIALS_SECRET_KEY=TU_AWS_SECRET_KEY
CLOUD_AWS_REGION_STATIC=us-east-2
CLOUD_AWS_S3_BUCKET=TU_S3_BUCKET

# Configuración de Moodle API
MOODLE_API_URL=https://virtuallab.ufps.edu.co/webservice/rest/server.php
MOODLE_API_TOKEN=TU_MOODLE_TOKEN

# Configuración de carga de archivos
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB
SPRING_DESTINATION_FOLDER=src/main/resources/static/

# Configuración de correo electrónico
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=TU_EMAIL@gmail.com
SPRING_MAIL_PASSWORD=TU_APP_PASSWORD_GMAIL
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_TRUST=smtp.gmail.com

# Configuración de codificación
SERVER_SERVLET_ENCODING_CHARSET=UTF-8
SERVER_SERVLET_ENCODING_ENABLED=true
SERVER_SERVLET_ENCODING_FORCE=true

# Configuración de errores y SQL
SERVER_ERROR_INCLUDE_MESSAGE=always
SPRING_SQL_INIT_MODE=always